# ============================================================================
# AI Provider Configuration
# ============================================================================

# Choose your AI provider: openai | gemini
AI_PROVIDER=openai

# ============================================================================
# OpenAI Configuration (if AI_PROVIDER=openai)
# ============================================================================

# Your OpenAI API key
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI model: dall-e-3 (HD, 1 image/request) | dall-e-2 (SD, up to 10/request)
OPENAI_MODEL=dall-e-3

# ============================================================================
# Gemini Configuration (if AI_PROVIDER=gemini)
# ============================================================================

# Your Google AI / Gemini API key
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini Imagen model options:
# - imagen-3.0-generate-002 (latest, best quality)
# - imagen-3.0-generate-001 
# - imagegeneration@006
GEMINI_MODEL=imagen-3.0-generate-002

# ============================================================================
# Server Configuration
# ============================================================================

PORT=3001
SERVER_API_URL=http://localhost:3001

# ============================================================================
# Frontend Configuration (legacy, used by frontend if needed)
# ============================================================================

VITE_USE_MOCK_API=false
VITE_AI_PROVIDER=openai
VITE_API_BASE_URL=https://testapi.getlokalapp.com
